{
  "name": "github-actions-search",
  "version": "0.0.6",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "rimraf dist && vite build",
    "typecheck": "tsgo -p . --noEmit",
    "lint": "run-p lint:*",
    "lint:oxfmt": "pnpm fix:oxfmt --check",
    "lint:oxlint": "oxlint --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --promise-plugin --vitest-plugin --ignore-path .gitignore --no-error-on-unmatched-pattern .",
    "lint:cspell": "cspell lint './**/*.{tsx,ts,mts,mcs,mjs,cjs,js,json,jsonc,md,yml,yaml}' --gitignore --cache",
    "fix": "run-p fix:*",
    "fix:oxfmt": "oxfmt --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "fix:oxlint": "pnpm lint:oxlint --fix",
    "test": "vitest --run",
    "test:watch": "vitest",
    "vrt": "playwright test",
    "vrt:update": "pnpm vrt --update-snapshots",
    "setup:check-manager": "npx -y only-allow pnpm",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "lucide-preact": "1.22.0",
    "preact": "10.29.3",
    "valibot": "1.0.0-beta.9"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@preact/preset-vite": "2.10.5",
    "@testing-library/dom": "10.4.0",
    "@testing-library/preact": "3.2.4",
    "@tsconfig/strictest": "2.0.5",
    "@types/node": "22.10.2",
    "@types/webextension-polyfill": "0.10.7",
    "@typescript/native-preview": "7.0.0-dev.20260628.1",
    "cspell": "8.17.1",
    "gatecheck": "0.0.1",
    "jsdom": "25.0.1",
    "lefthook": "1.10.1",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "playwright": "1.49.1",
    "release-it": "17.11.0",
    "release-it-pnpm": "4.6.3",
    "rimraf": "6.0.1",
    "typescript": "5.6.3",
    "vite": "5.4.11",
    "vite-plugin-web-extension": "4.3.1",
    "vitest": "2.1.8",
    "webextension-polyfill": "0.10.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
